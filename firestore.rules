// firestore.rules
// ─────────────────────────────────────────────────────────────
//  Firestore Security Rules for CampusBus
//  Deploy: firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────
    function isSignedIn()         { return request.auth != null; }
    function isAdmin()            { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isDriver(uid)        { return isSignedIn() && exists(/databases/$(database)/documents/drivers/$(uid)); }
    function isStudent(uid)       { return isSignedIn() && exists(/databases/$(database)/documents/students/$(uid)); }
    function isSelf(uid)          { return isSignedIn() && request.auth.uid == uid; }

    // ── Admins collection ───────────────────────────────────
    match /admins/{uid} {
      allow read:  if isSelf(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // ── Drivers collection ──────────────────────────────────
    match /drivers/{uid} {
      allow read:  if isSignedIn();                     // students can read driver info (name, phone, route)
      allow create:if isAdmin();                         // only admin creates driver profiles
      allow update:if isSelf(uid) || isAdmin();          // driver updates own location; admin updates anything
      allow delete:if isAdmin();
    }

    // ── Driver profiles (pre-created by admin before first login) ──
    match /driver_profiles/{phone} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Routes collection ───────────────────────────────────
    match /routes/{routeId} {
      allow read:  if isSignedIn();                     // everyone can read routes
      allow write: if isAdmin();                         // only admin can create/edit/delete routes
    }

    // ── Students collection ─────────────────────────────────
    match /students/{uid} {
      allow read:  if isSelf(uid) || isAdmin() || isDriver(request.auth.uid); // driver sees students on their route
      allow create:if isSelf(uid);                       // student creates own profile on registration
      allow update:if isSelf(uid) || isAdmin();          // student updates own FCM token; admin changes status
      allow delete:if isAdmin();
    }

    // ── Buses (live GPS positions) ──────────────────────────
    match /buses/{driverUid} {
      allow read:  if isSignedIn();                     // students + admin read live positions
      allow write: if isSelf(driverUid) || isAdmin();   // only that driver writes their own position
    }

    // ── Trips ───────────────────────────────────────────────
    match /trips/{tripId} {
      allow read:  if isSignedIn();
      allow create:if isDriver(request.auth.uid) || isAdmin();
      allow update:if isDriver(request.auth.uid) || isAdmin();
      allow delete:if isAdmin();
    }

    // ── Attendance ──────────────────────────────────────────
    match /attendance/{recordId} {
      allow read:  if isSignedIn();
      allow create:if isDriver(request.auth.uid) || isAdmin();
      allow update:if isDriver(request.auth.uid) || isAdmin();
      allow delete:if isAdmin();
    }

    // ── Reports (generated by Cloud Functions) ──────────────
    match /reports/{date} {
      allow read:  if isAdmin();
      allow write: if false;                             // only Cloud Functions write reports
    }
  }
}
